:root {
    --font-default: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    
    --color-background: #FAFAFA;
    --color-window: #FFFFFF;
    --color-window-negative: #000000;
    --color-text: #444444;
    --color-border: #B8B8B8;
    --color-brand-primary: #006AFF;
    --color-brand-hover: #3387FF;
    --color-brand-additional: #7A7A7A;
    --color-error: #E64444;
    --color-notification: #F75555;
    --color-buttons-default: #F3F3F3;
    
    --width-sidebar: 210px;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

a {
    text-decoration: none;
}

/* header */

.header {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 6px 0px;

    width: 100%;
    height: fit-content;

    background: var(--color-window);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.25);

    /* Inside auto layout */
    flex: none;
    order: 0;
    align-self: stretch;
    flex-grow: 0;
}

/* logo */

.logo {
    /* Auto layout */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 0px;

    width: calc(var(--width-sidebar) - 1px); /* 1px for the stroke */
    height: 100%;


    /* Inside auto layout */
    flex: none;
    order: 0;
    align-self: stretch;
    flex-grow: 0;
}

/* left_align */

.left_align {
    /* Auto layout */
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0px;

    width: fit-content;
    height: fit-content;


    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* AuraConnect */

.left_align h1 {
    width: fit-content;
    height: fit-content;

    font-family: var(--font-default);
    font-style: normal;
    font-weight: 900;
    font-size: 20px;
    line-height: 24px;

    color: var(--color-brand-primary);

    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* Коммуникационная платформа */

.left_align p {
    width: fit-content;
    height: fit-content;

    font-family: var(--font-default);
    font-style: normal;
    font-weight: 400;
    font-size: 10px;
    line-height: 12px;

    color: var(--color-brand-additional);


    /* Inside auto layout */
    flex: none;
    order: 1;
    flex-grow: 0;
}

/* navigation */

.navigation {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 0px;

    height: 42px;


    /* Inside auto layout */
    flex: none;
    order: 1;
    flex-grow: 1;
}

/* stroke_margin */

.stroke_margin {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 5px 0.1px;
    gap: 10px;

    width: fit-content;
    height: 100%;


    /* Inside auto layout */
    flex: none;
    order: 0;
    align-self: stretch;
    flex-grow: 0;
}

/* stroke */

.stroke {
    width: 0.8px;
    height: 100%;

    background: var(--color-border);

    /* Inside auto layout */
    flex: none;
    order: 0;
    align-self: stretch;
    flex-grow: 0;
}

/* navigation_gap */

.navigation_gap {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 0px;
    gap: 65px;

    height: fit-content;


    /* Inside auto layout */
    flex: none;
    order: 1;
    flex-grow: 1;
}

/* tabs_container */

.tabs_container {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 0px 0px 0px 5px;

    height: fit-content;


    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 1;
}

/* tab_container_arrow */

.tab_container_arrow {
    /* Auto layout */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 10px 7px;
    gap: 10px;

    width: fit-content;

    background: var(--color-window);

    /* Inside auto layout */
    flex: none;
    order: 0;
    align-self: stretch;
    flex-grow: 0;
}

/* tabs */

.tabs {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 3px 0px;
    gap: 2px;

    height: fit-content;
    overflow-x: scroll;
    
    &::-webkit-scrollbar {
      display: none;
    }
    scrollbar-width: none;
    -ms-overflow-style: none;


    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-basis: 0%;
    flex-grow: 1;
}

/* tab */

.tab {
    /* Auto layout */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0px;
    gap: 1.5px;

    width: 171.5px;
    height: 35.5px;

    /* Inside auto layout */
    flex: none;
    order: 1;
    flex-grow: 0;
}

.tab.active {
    align-items: flex-start;
    justify-content: flex-start;
}

/* card */

.card {
    box-sizing: border-box;

    /* Auto layout */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 6px 6px 4px 9.5px;
    gap: 1px;

    width: fit-content;
    height: fit-content;

    background: var(--color-buttons-default);
    border: 1px solid var(--color-border);
    border-radius: 10px;

    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

.card.active {
    background: var(--color-window);
    box-shadow: 2px 2px 2px 0.5px rgba(0, 0, 0, 0.25);
}

/* tab_content */

.tab_content {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 0px;
    gap: 4px;

    width: fit-content;
    height: fit-content;


    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* tab_icon */

.tab_icon {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 0px;
    gap: 10px;

    width: 13px;
    height: 13px;


    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* flex_content */

.flex_content {
    position: relative;
    width: 135px;
    height: 20px;


    /* Inside auto layout */
    flex: none;
    order: 1;
    flex-grow: 0;
}

/* close */

.close {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
    padding: 0px;
    gap: 10px;

    position: absolute;
    width: 20px;
    height: 20px;
    left: 115px;
    top: 0px;

    background: var(--color-window);
    box-shadow: -4px 0px 4px 1px var(--color-window);
    border-radius: 4px;
}

/* tab_close_background */

.tab_close_background {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 0px 0px 0px 1px;
    gap: 10px;

    width: 14px;
    height: 20px;


    /* Inside auto layout */
    flex: none;
    order: 0;
    align-self: stretch;
    flex-grow: 0;
}

/* tab_name_field */

.tab_name_field {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 0px 0px 1px;

    position: absolute;
    width: 140px;
    height: 20px;
    left: 0px;
    top: 0px;
}

/* name */

.tab_name_field p {
    width: 108px;
    height: 16px;

    font-family: var(--font-default);
    font-style: normal;
    font-weight: 400;
    font-size: 13px;
    line-height: 16px;
    /* identical to box height */

    color: #444444;
    

    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* flex_container_tab_stroke */

.card .flex_container_tab_stroke {
    display: none;
    
    position: relative;
    width: 152px;
    height: 0px;


    /* Inside auto layout */
    flex: none;
    order: 1;
    align-self: stretch;
    flex-grow: 0;
}

.card.active .flex_container_tab_stroke {
    display: block;
}

/* tab_stroke */

.tab_stroke {
    position: absolute;
    width: 155.5px;
    height: 1px;
    transform: scaleY(0.5); /* Сжимаем до 0.5 визуально */
    transform-origin: top;
    left: -3.5px;
    top: 0px;

    background: var(--color-brand-primary);
}

/* searchline_container */

.searchline_container {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 0px;
    gap: 10px;

    width: 337px;
    height: fit-content;


    /* Inside auto layout */
    flex: none;
    order: 1;
    flex-grow: 0;
}

/* searchline */

.searchline {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 2px 5px;
    gap: 10px;

    width: 100%;
    height: fit-content;

    border-radius: 7px;

    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* insert_line */

.insert_line {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 7px 50px;
    gap: 10px;

    width: fit-content;
    height: fit-content;

    background: var(--color-buttons-default);
    border: 0.5px solid var(--color-border);
    border-radius: 7px;

    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* Поиск клиентов, звонков, задач.... */

.insert_line p {
    width: fit-content;
    height: fit-content;

    font-family: var(--font-default);
    font-style: normal;
    font-weight: 400;
    font-size: 12px;
    line-height: 15px;
    /* identical to box height */

    color: var(--color-text);


    /* Inside auto layout */
    flex: none;
    order: 1;
    flex-grow: 0;
}

/* right_part */

.right_part {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 0px 20px 0px 0px;
    gap: 29px;

    width: fit-content;


    /* Inside auto layout */
    flex: none;
    order: 2;
    align-self: stretch;
    flex-grow: 0;
}

/* notifications */

.notifications {
    position: relative;
    width: 24px;
    height: 21px;


    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* number_background */

.number_background {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 0.5px 3px;
    gap: 10px;

    position: absolute;
    width: fit-content;
    min-width: 13px;
    height: fit-content;
    right: 11px;
    top: -4px;

    background: var(--color-notification);
    border-radius: 50%;
    z-index: 100;
}

/* 5 */

.number_background p {
    width: fit-content;
    height: fit-content;

    font-family: var(--font-default);
    font-style: normal;
    font-weight: 600;
    font-size: 10.1111px;
    line-height: 12px;

    color: var(--color-window);
    z-index: 100;
}

/* hover_background_notifications */

.hover_background_notifications {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 0px;
    gap: 10px;

    position: absolute;
    width: 44px;
    height: 54px;
    left: -6.5px;
    top: -16px;
}

/* history */

.history {
    position: relative;
    width: 21px;
    height: 21px;


    /* Inside auto layout */
    flex: none;
    order: 1;
    flex-grow: 0;
}

/* hover_background_history */

.hover_background_history {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 0px;
    gap: 10px;

    position: absolute;
    width: 44px;
    height: 54px;
    left: -11.5px;
    top: -16.5px;
}

/* profile_info */

.profile_info {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 0px;
    gap: 9px;

    width: fit-content;
    height: 100%;


    /* Inside auto layout */
    flex: none;
    order: 2;
    align-self: stretch;
    flex-grow: 0;
}

/* role_and_picture */

.role_and_picture {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 3px;
    gap: 10px;

    width: fit-content;
    height: fit-content;

    background: linear-gradient(130.21deg, #ED86FF 15.57%, #510060 134.16%);
    border-radius: 50%;

    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* picture */

.picture {
    /* Auto layout */
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 10px;

    width: 35px;
    height: 35px;

    background: var(--color-brand-primary);
    border: 1px solid var(--color-border);
    border-radius: 50%;

    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* ИИ */

.picture p {
    width: fit-content;
    height: 18px;

    font-family: var(--font-style);
    font-style: normal;
    font-weight: 400;
    font-size: 15px;
    line-height: 18px;

    color: var(--color-window);


    /* Inside auto layout */
    flex: none;
    order: 0;
    flex-grow: 0;
}

/* name */

.name p {
    width: fit-content;
    max-width: 304px;
    height: fit-content;

    font-family: var(--font-default);
    font-style: normal;
    font-weight: 400;
    font-size: 16px;
    line-height: 19px;

    color: var(--color-window-negative);


    /* Inside auto layout */
    flex: none;
    order: 1;
    flex-grow: 0;
}

